# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# OpenRouter API Key (Required)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Cloudflare Gateway Base URL (Required for China access)
# Format: https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}/openrouter/v1/chat/completions
OPENROUTER_BASE_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_ID/openrouter/v1/chat/completions

# Cloudflare AI Gateway Token (Required for Gateway authentication)
# Get your token from: Cloudflare Dashboard > AI Gateway > Your Gateway > Tokens
CF_AIG_TOKEN=cfut_your-cloudflare-gateway-token-here

# Optional: Custom save directories
# SAVE_DIR=./materials/raw
# SAVE_DIR_EDIT=./materials/raw_edit